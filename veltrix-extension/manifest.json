{
  "manifest_version": 3,
  "name": "Veltrix AI - Phishing Shield",
  "version": "1.0.0",
  "description": "Real-time AI-powered phishing detection for Gmail. Auto-scans emails, blocks phishing links, and color-codes threats.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "webNavigation",
    "declarativeNetRequest",
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:8000/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["config.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "config.js",
        "blocked.html",
        "dashboard.html",
        "dashboard.js",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
